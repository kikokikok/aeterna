{
  "info": {
    "name": "Aeterna E2E Test Suite",
    "description": "End-to-end tests for the Aeterna stack via HTTPS ingress.\n\n1. Deployment Validation — health, readiness, liveness, 404 fallback\n2. Admin Features & Configuration — OpenSpec discovery, governance, A2A, MCP\n3. Realistic Scenario — Full knowledge CRUD lifecycle",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.1.0"
  },

  "variable": [
    { "key": "baseUrl", "value": "https://aeterna.ci-dev-04.dev.kyriba.io", "type": "string" },
    { "key": "knowledgeId", "value": "", "type": "string" },
    { "key": "knowledgeCommit", "value": "", "type": "string" },
    { "key": "batchId1", "value": "", "type": "string" },
    { "key": "batchId2", "value": "", "type": "string" },
    { "key": "scenarioRunTs", "value": "", "type": "string" }
  ],

  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response time < 5000ms', () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});"
        ]
      }
    }
  ],

  "item": [
    {
      "name": "1. Deployment Validation",
      "item": [
        {
          "name": "1.1 Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Health response has status ok and version', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('ok');",
                  "    pm.expect(json.version).to.match(/^\\d+\\.\\d+\\.\\d+/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "1.2 Liveness Probe",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Empty body', () => pm.expect(pm.response.text()).to.have.lengthOf(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/live", "host": ["{{baseUrl}}"], "path": ["live"] }
          }
        },
        {
          "name": "1.3 Readiness Probe",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Ready with postgres and vector_store ok', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('ready');",
                  "    pm.expect(json.checks.postgres.status).to.eql('ok');",
                  "    pm.expect(json.checks.vector_store.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/ready", "host": ["{{baseUrl}}"], "path": ["ready"] }
          }
        },
        {
          "name": "1.4 404 Fallback",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));",
                  "",
                  "pm.test('Structured error JSON', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error).to.eql('not_found');",
                  "    pm.expect(json.message).to.eql('Route not found');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/nonexistent-route-e2e-test", "host": ["{{baseUrl}}"], "path": ["nonexistent-route-e2e-test"] }
          }
        }
      ]
    },

    {
      "name": "2. Admin Features & Configuration",
      "item": [
        {
          "name": "2.1 OpenSpec Knowledge Discovery",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Service info and endpoints', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.service).to.eql('aeterna-openspec');",
                  "    pm.expect(json.version).to.be.a('string');",
                  "    pm.expect(json.endpoints).to.be.an('array');",
                  "    pm.expect(json.endpoints.length).to.be.at.least(6);",
                  "    const paths = json.endpoints.map(e => e.path);",
                  "    pm.expect(paths).to.include('/openspec/v1/knowledge/query');",
                  "    pm.expect(paths).to.include('/openspec/v1/knowledge/create');",
                  "    pm.expect(paths).to.include('/openspec/v1/knowledge/batch');",
                  "    pm.expect(paths).to.include('/openspec/v1/knowledge/stream');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge"] }
          }
        },
        {
          "name": "2.2 Governance - List Proposals",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Valid JSON', () => pm.response.json());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/governance/proposals", "host": ["{{baseUrl}}"], "path": ["api", "v1", "governance", "proposals"] }
          }
        },
        {
          "name": "2.3 Governance - List Jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Valid JSON', () => pm.response.json());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/governance/jobs", "host": ["{{baseUrl}}"], "path": ["api", "v1", "governance", "jobs"] }
          }
        },
        {
          "name": "2.4 Governance - Drift Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));",
                  "pm.test('Valid JSON', () => pm.response.json());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/governance/drift-config/e2e-test-project", "host": ["{{baseUrl}}"], "path": ["api", "v1", "governance", "drift-config", "e2e-test-project"] }
          }
        },
        {
          "name": "2.5 Governance - Drift Detection",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));",
                  "pm.test('Valid JSON', () => pm.response.json());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/governance/drift/e2e-test-project", "host": ["{{baseUrl}}"], "path": ["api", "v1", "governance", "drift", "e2e-test-project"] }
          }
        },
        {
          "name": "2.6 Governance - Reports",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));",
                  "pm.test('Valid JSON', () => pm.response.json());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/governance/reports/e2e-test-org", "host": ["{{baseUrl}}"], "path": ["api", "v1", "governance", "reports", "e2e-test-org"] }
          }
        },
        {
          "name": "2.7 Governance - Event Replay",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Valid JSON', () => pm.response.json());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/governance/events/replay?since_timestamp=0&limit=100", "host": ["{{baseUrl}}"], "path": ["api", "v1", "governance", "events", "replay"], "query": [{"key": "since_timestamp", "value": "0"}, {"key": "limit", "value": "100"}] }
          }
        },
        {
          "name": "2.8 A2A Agent Card",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Agent card has name', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('name');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/a2a/.well-known/agent.json", "host": ["{{baseUrl}}"], "path": ["a2a", ".well-known", "agent.json"] }
          }
        },
        {
          "name": "2.9 MCP SSE Endpoint",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('MCP SSE responds', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));",
                  "",
                  "pm.test('Content-Type is event-stream if 200', () => {",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/mcp/sse", "host": ["{{baseUrl}}"], "path": ["mcp", "sse"] }
          },
          "protocolProfileBehavior": { "disableBodyPruning": true }
        },
        {
          "name": "2.10 MCP Message Endpoint",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Reachable (not 404)', () => pm.expect(pm.response.code).to.not.eql(404));",
                  "pm.test('Valid JSON', () => pm.response.json());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/mcp/message", "host": ["{{baseUrl}}"], "path": ["mcp", "message"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"jsonrpc\":\"2.0\",\"method\":\"ping\",\"id\":1}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "2.11 A2A Task Submit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Reachable (not 404)', () => pm.expect(pm.response.code).to.not.eql(404));",
                  "pm.test('Valid JSON', () => pm.response.json());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/a2a/tasks/send", "host": ["{{baseUrl}}"], "path": ["a2a", "tasks", "send"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"jsonrpc\":\"2.0\",\"method\":\"tasks/send\",\"id\":\"e2e-test\",\"params\":{\"id\":\"e2e-task-1\",\"message\":{\"role\":\"user\",\"parts\":[{\"type\":\"text\",\"text\":\"ping\"}]}}}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },

    {
      "name": "3. Realistic Scenario — Knowledge CRUD Lifecycle",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('scenarioRunTs')) {",
              "    pm.collectionVariables.set('scenarioRunTs', String(Date.now()));",
              "}"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "3.1 Create Knowledge Entry",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "",
                  "pm.test('Has id and commit', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('string').and.not.be.empty;",
                  "    pm.expect(json.commit).to.be.a('string').and.not.be.empty;",
                  "    pm.collectionVariables.set('knowledgeId', json.id);",
                  "    pm.collectionVariables.set('knowledgeCommit', json.commit);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge/create", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge", "create"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"# E2E Test Entry\\n\\nCreated by Newman at {{scenarioRunTs}}.\",\n  \"path\": \"e2e-test-{{scenarioRunTs}}\",\n  \"layer\": \"project\",\n  \"tags\": [\"e2e\", \"newman\"],\n  \"metadata\": {\"source\": \"newman-e2e\", \"run_ts\": \"{{scenarioRunTs}}\"}\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "3.2 Query Knowledge",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": ["if (!pm.collectionVariables.get('knowledgeId')) throw new Error('knowledgeId not set');"] }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Has items and total', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array');",
                  "    pm.expect(json.total).to.be.a('number');",
                  "    pm.expect(json.items.length).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge/query", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge", "query"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"e2e-test\", \"limit\": 50, \"layer\": \"project\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "3.3 Get Metadata",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": ["if (!pm.collectionVariables.get('knowledgeId')) throw new Error('knowledgeId not set');"] }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Metadata fields', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.eql(pm.collectionVariables.get('knowledgeId'));",
                  "    pm.expect(json.layer).to.eql('project');",
                  "    pm.expect(json.tags).to.include('e2e');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge/{{knowledgeId}}/metadata", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge", "{{knowledgeId}}", "metadata"] }
          }
        },
        {
          "name": "3.4 Update Knowledge Entry",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": ["if (!pm.collectionVariables.get('knowledgeId')) throw new Error('knowledgeId not set');"] }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Updated id and commit', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.eql(pm.collectionVariables.get('knowledgeId'));",
                  "    pm.expect(json.commit).to.be.a('string').and.not.be.empty;",
                  "    pm.collectionVariables.set('knowledgeCommit', json.commit);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge/{{knowledgeId}}", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge", "{{knowledgeId}}"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"# E2E Test Entry (UPDATED)\\n\\nUpdated by Newman at {{scenarioRunTs}}.\",\n  \"path\": \"e2e-test-{{scenarioRunTs}}\",\n  \"tags\": [\"e2e\", \"newman\", \"updated\"],\n  \"metadata\": {\"source\": \"newman-e2e\", \"updated\": true}\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "3.5 Query Updated Entry",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Results found', () => pm.expect(pm.response.json().total).to.be.at.least(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge/query", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge", "query"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"e2e-test\", \"limit\": 50, \"layer\": \"project\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "3.6 Batch Create",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Both batch ops succeeded', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.results).to.be.an('array').with.lengthOf(2);",
                  "    json.results.forEach((r, i) => {",
                  "        pm.expect(r.success).to.be.true;",
                  "        pm.expect(r.id).to.be.a('string').and.not.be.empty;",
                  "    });",
                  "    pm.collectionVariables.set('batchId1', json.results[0].id);",
                  "    pm.collectionVariables.set('batchId2', json.results[1].id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge/batch", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge", "batch"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operations\": [\n    {\"action\": \"create\", \"content\": \"Batch 1 at {{scenarioRunTs}}\", \"path\": \"e2e-batch1-{{scenarioRunTs}}\", \"layer\": \"project\", \"tags\": [\"e2e\", \"batch\"]},\n    {\"action\": \"create\", \"content\": \"Batch 2 at {{scenarioRunTs}}\", \"path\": \"e2e-batch2-{{scenarioRunTs}}\", \"layer\": \"project\", \"tags\": [\"e2e\", \"batch\"]}\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "3.7 Query Batch Entries",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": ["if (!pm.collectionVariables.get('batchId1')) throw new Error('batchId1 not set');"] }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Batch entries found', () => pm.expect(pm.response.json().total).to.be.at.least(2));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge/query", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge", "query"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"e2e-batch\", \"limit\": 50, \"layer\": \"project\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "3.8 SSE Stream Connectivity",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('SSE responds 200', () => pm.response.to.have.status(200));",
                  "pm.test('Event-stream content type', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream'));",
                  "pm.test('Connected event', () => pm.expect(pm.response.text()).to.include('connected'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/openspec/v1/knowledge/stream", "host": ["{{baseUrl}}"], "path": ["openspec", "v1", "knowledge", "stream"] }
          },
          "protocolProfileBehavior": { "disableBodyPruning": true }
        },
        {
          "name": "3.9 Delete Original Entry",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": ["if (!pm.collectionVariables.get('knowledgeId')) throw new Error('knowledgeId not set');"] }
            },
            {
              "listen": "test",
