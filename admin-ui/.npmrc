# openapi-typescript@7.13.0 (latest) declares a conservative peer
# `typescript@^5.x`, but it is a build-time CLI codegen tool (parses
# OpenAPI YAML, emits .ts source — it is never imported at runtime),
# so the peer constraint is theoretical-only. We are on TS 6 and the
# generated output works correctly.
#
# This flag matches npm's own suggested workaround in the ERESOLVE
# error output and is scoped to admin-ui only. Remove this when an
# openapi-typescript release ships with TS 6 in its peer range.
legacy-peer-deps=true
