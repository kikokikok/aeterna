# PARKED — Wave 2a follow-up (see PR #35 commit 406030d / follow-up issue).
#
# This workflow's original trigger referenced `branches: [main, develop]`,
# but the default branch is `master` — so it had never actually run.
# Wave 2a fixed the trigger, which immediately exposed pre-existing
# template bugs in the "Lint hardened fixtures" and "Template Validation"
# jobs: EVERY fixture in charts/aeterna/{ci,examples}/ fails `helm
# template` because the chart requires postgresql.host / redis.host /
# vectorStore.host at render time (enforced by fail()) and none of the
# fixtures stub these.
#
# For PR gating we now rely on pr-fast.yml's `helm-lint-template` job,
# which uses `--set` overrides to render + kubeconform-validate.
#
# This workflow needs a follow-up PR that either:
#   (a) Updates all ci/*.yaml + examples/*.yaml fixtures to stub prereqs.
#   (b) Wraps them with `helm template ... | xargs -r ...` using
#       aeterna-prereqs chart alongside.
#   (c) Deletes the `.bak` if the coverage is deemed redundant.

name: Helm Chart CI

on:
  pull_request:
    branches: [master]
    paths:
      - 'charts/**'
      - '.github/workflows/helm-ci.yml'

jobs:
  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Helm
        uses: azure/setup-helm@v4
        with:
          version: v3.14.0

      - name: Helm Lint default chart
        run: helm lint charts/aeterna

      - name: Helm Lint hardened fixtures
        run: |
          helm lint charts/aeterna -f charts/aeterna/examples/values-production.yaml
          helm lint charts/aeterna -f charts/aeterna/examples/values-sops.yaml
          helm lint charts/aeterna -f charts/aeterna/values-small.yaml
          helm lint charts/aeterna -f charts/aeterna/values-medium.yaml
          helm lint charts/aeterna -f charts/aeterna/values-large.yaml
          helm lint charts/aeterna -f charts/aeterna/ci/okta-values.yaml
          helm lint charts/aeterna -f charts/aeterna/ci/hybrid-values.yaml
          helm lint charts/aeterna -f charts/aeterna/ci/remote-values.yaml
          helm lint charts/aeterna -f charts/aeterna/ci/external-deps-values.yaml
          helm lint charts/aeterna -f charts/aeterna/ci/chart-managed-external-secrets-values.yaml
          ! helm lint charts/aeterna -f charts/aeterna/ci/okta-invalid-values.yaml

  template:
    name: Template Validation
    runs-on: ubuntu-latest
    strategy:
      matrix:
        values:
          - default
          - local
          - ci-okta
          - ci-hybrid
          - ci-remote
          - remote
          - production
          - hybrid
          - large
          - ci-external-deps
          - ci-chart-managed-external-secrets
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Helm
        uses: azure/setup-helm@v4
        with:
          version: v3.14.0

      - name: Template with default values
        if: matrix.values == 'default'
        run: helm template aeterna charts/aeterna --debug

      - name: Template with example values
        if: contains(fromJson('["local","production","hybrid"]'), matrix.values)
        run: helm template aeterna charts/aeterna -f charts/aeterna/examples/values-${{ matrix.values }}.yaml --debug

      - name: Template with supported preset values
        if: contains(fromJson('["remote","large"]'), matrix.values)
        run: helm template aeterna charts/aeterna -f charts/aeterna/values-${{ matrix.values }}.yaml --debug

      - name: Template with CI mode fixtures
        if: contains(fromJson('["ci-okta","ci-hybrid","ci-remote"]'), matrix.values)
        run: |
          case "${{ matrix.values }}" in
            ci-okta) helm template aeterna charts/aeterna -f charts/aeterna/ci/okta-values.yaml --debug ;;
            ci-hybrid) helm template aeterna charts/aeterna -f charts/aeterna/ci/hybrid-values.yaml --debug ;;
            ci-remote) helm template aeterna charts/aeterna -f charts/aeterna/ci/remote-values.yaml --debug ;;
          esac

      - name: Template with CI fixture values
        if: matrix.values == 'ci-external-deps'
        run: helm template aeterna charts/aeterna -f charts/aeterna/ci/external-deps-values.yaml --debug

      - name: Template with chart-managed secret fixture
        if: matrix.values == 'ci-chart-managed-external-secrets'
        run: helm template aeterna charts/aeterna -f charts/aeterna/ci/chart-managed-external-secrets-values.yaml --debug

  kubeconform:
    name: Kubernetes Schema Validation
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Helm
        uses: azure/setup-helm@v4
        with:
          version: v3.14.0

      - name: Install kubeconform
        run: |
          curl -sL https://github.com/yannh/kubeconform/releases/download/v0.6.4/kubeconform-linux-amd64.tar.gz | tar xz
          sudo mv kubeconform /usr/local/bin/

      - name: Validate Kubernetes manifests
        run: |
          helm template aeterna charts/aeterna | kubeconform \
            -strict \
            -ignore-missing-schemas \
            -kubernetes-version 1.29.0 \
            -summary

  schema-validation:
    name: Values Schema Validation
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Install jsonschema
        run: pip install jsonschema pyyaml

      - name: Validate values against schema
        run: |
          python -c "
          import json
          import yaml
          from jsonschema import validate, ValidationError

          with open('charts/aeterna/values.schema.json') as f:
              schema = json.load(f)
          
          with open('charts/aeterna/values.yaml') as f:
              values = yaml.safe_load(f)
          
          try:
              validate(instance=values, schema=schema)
              print('Values schema validation passed')
          except ValidationError as e:
              print(f'Schema validation failed: {e.message}')
              exit(1)
          "

  chart-testing:
    name: Chart Testing
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Helm
        uses: azure/setup-helm@v4
        with:
          version: v3.14.0

      - name: Set up chart-testing
        uses: helm/chart-testing-action@v2.6.1

      - name: List changed charts
        id: list-changed
        run: |
          changed=$(ct list-changed --config .github/ct.yaml 2>/dev/null || echo "charts/aeterna")
          if [[ -n "$changed" ]]; then
            echo "changed=true" >> "$GITHUB_OUTPUT"
          fi

      - name: Run chart-testing (lint)
        run: ct lint --config .github/ct.yaml --charts charts/aeterna

  docs:
    name: Documentation Check
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Check README exists
        run: |
          if [[ ! -f charts/aeterna/README.md ]]; then
            echo "ERROR: charts/aeterna/README.md is missing"
            exit 1
          fi

      - name: Check values documentation
        run: |
          if ! grep -q "## Values Reference" charts/aeterna/README.md; then
            echo "WARNING: Values Reference section missing from README"
          fi
